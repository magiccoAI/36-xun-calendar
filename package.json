{
  "name": "a-year-in-36-multiple-10-perspective-calendar",
  "version": "1.2.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "clean": "npx rimraf debug-*.html verify-*.html",
    "dev": "vite",
    "build": "npm run build:css && npm run build:images && vite build",
    "preview": "vite preview",
    "build:css": "npx tailwindcss -i ./src/input.css -o ./src/output.css --minify",
    "watch:css": "npx tailwindcss -i ./src/input.css -o ./src/output.css --watch",
    "optimize:images": "cd src/images && node optimize-images.js",
    "build:images": "npm run optimize:images",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:e2e": "playwright test"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {},
    "testMatch": [
      "<rootDir>/src/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/tests/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 75,
        "lines": 75,
        "statements": 75
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.23",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "vite": "^8.0.5"
  }
}
